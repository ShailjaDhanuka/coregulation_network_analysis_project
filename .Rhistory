for(m in rownames(moduleTraitCor)){
best_cluster <- which.max(abs(moduleTraitCor[m,]))
best_cor     <- moduleTraitCor[m, best_cluster]
best_p       <- moduleTraitPvalue[m, best_cluster]
cat(m, "→ strongest with", names(best_cluster),
"| cor =", round(best_cor, 2),
"| p =", round(best_p, 3), "\n")
}
